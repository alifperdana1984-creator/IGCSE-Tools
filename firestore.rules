rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Data Model
    // ===============================================================
    //
    // Collection: assessments
    // Fields:
    //   - subject: string (required)
    //   - topic: string (required)
    //   - difficulty: string
    //   - questions: list (required) — array of QuestionItem objects
    //   - createdAt: timestamp (required)
    //   - userId: string (required)
    //   - folderId: string (optional)
    //
    // Collection: questions
    // Fields:
    //   - subject: string (required)
    //   - topic: string (required)
    //   - difficulty: string
    //   - text: string (required) — markdown question text
    //   - answer: string (optional)
    //   - markScheme: string (optional)
    //   - marks: number (optional)
    //   - commandWord: string (optional)
    //   - type: string (optional)
    //   - hasDiagram: bool (optional)
    //   - assessmentId: string (optional)
    //   - folderId: string (optional)
    //   - createdAt: timestamp (required)
    //   - userId: string (required)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidAssessment(data) {
      return hasOnlyAllowedFields(['subject', 'topic', 'difficulty', 'questions', 'code', 'userId', 'createdAt', 'folderId', 'isPublic', 'preparedBy']) &&
             data.subject is string && data.subject.size() > 0 && data.subject.size() < 100 &&
             data.topic is string && data.topic.size() > 0 && data.topic.size() < 200 &&
             data.questions is list &&
             data.userId == request.auth.uid &&
             data.createdAt is timestamp &&
             (!('folderId' in data) || data.folderId == null || data.folderId is string) &&
             (!('difficulty' in data) || data.difficulty == null || data.difficulty is string) &&
             (!('isPublic' in data) || data.isPublic == null || data.isPublic is bool) &&
             (!('preparedBy' in data) || data.preparedBy == null || data.preparedBy is string);
    }

    function isValidFolder(data) {
      return hasOnlyAllowedFields(['name', 'userId', 'createdAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.userId == request.auth.uid &&
             data.createdAt is timestamp;
    }

    function isValidResource(data) {
      return hasOnlyAllowedFields(['name', 'subject', 'storagePath', 'downloadURL', 'mimeType', 'userId', 'createdAt', 'resourceType', 'geminiFileUri', 'geminiFileUploadedAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.subject is string && data.subject.size() > 0 &&
             data.storagePath is string && data.storagePath.size() > 0 &&
             data.downloadURL is string && data.downloadURL.size() > 0 &&
             data.mimeType is string &&
             data.userId == request.auth.uid &&
             data.createdAt is timestamp &&
             (!('resourceType' in data) || data.resourceType == null || data.resourceType is string) &&
             (!('geminiFileUri' in data) || data.geminiFileUri == null || data.geminiFileUri is string) &&
             (!('geminiFileUploadedAt' in data) || data.geminiFileUploadedAt == null || data.geminiFileUploadedAt is timestamp);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidQuestion(data) {
      return hasOnlyAllowedFields(['subject', 'topic', 'difficulty', 'text', 'answer', 'markScheme', 'marks', 'commandWord', 'type', 'hasDiagram', 'diagramMissing', 'diagram', 'code', 'userId', 'createdAt', 'assessmentId', 'folderId', 'isPublic', 'preparedBy', 'syllabusObjective', 'difficultyStars', 'options', 'assessmentObjective']) &&
             data.subject is string && data.subject.size() > 0 &&
             data.topic is string && data.topic.size() > 0 &&
             data.text is string && data.text.size() > 0 && data.text.size() < 10000 &&
             data.userId == request.auth.uid &&
             data.createdAt is timestamp &&
             (!('marks' in data) || data.marks == null || data.marks is number) &&
             (!('commandWord' in data) || data.commandWord == null || data.commandWord is string) &&
             (!('type' in data) || data.type == null || data.type is string) &&
             (!('hasDiagram' in data) || data.hasDiagram == null || data.hasDiagram is bool) &&
             (!('answer' in data) || data.answer == null || data.answer is string) &&
             (!('markScheme' in data) || data.markScheme == null || data.markScheme is string) &&
             (!('assessmentId' in data) || data.assessmentId == null || data.assessmentId is string) &&
             (!('folderId' in data) || data.folderId == null || data.folderId is string) &&
             (!('isPublic' in data) || data.isPublic == null || data.isPublic is bool) &&
             (!('preparedBy' in data) || data.preparedBy == null || data.preparedBy is string) &&
             (!('syllabusObjective' in data) || data.syllabusObjective == null || data.syllabusObjective is string) &&
             (!('difficultyStars' in data) || data.difficultyStars == null || data.difficultyStars is number);
    }

    // Update validators skip hasOnlyAllowedFields — existing docs may have fields
    // from older schema versions that are no longer in the create-time allowed list.
    function isValidQuestionUpdate(data) {
      return data.userId == request.auth.uid &&
             data.createdAt == resource.data.createdAt &&
             data.subject is string && data.subject.size() > 0 &&
             data.topic is string && data.topic.size() > 0 &&
             data.text is string && data.text.size() > 0 && data.text.size() < 10000 &&
             (!('isPublic' in data) || data.isPublic == null || data.isPublic is bool) &&
             (!('preparedBy' in data) || data.preparedBy == null || data.preparedBy is string);
    }

    function isValidAssessmentUpdate(data) {
      return data.userId == request.auth.uid &&
             data.createdAt == resource.data.createdAt &&
             data.subject is string && data.subject.size() > 0 && data.subject.size() < 100 &&
             data.topic is string && data.topic.size() > 0 && data.topic.size() < 200 &&
             data.questions is list &&
             (!('isPublic' in data) || data.isPublic == null || data.isPublic is bool) &&
             (!('preparedBy' in data) || data.preparedBy == null || data.preparedBy is string);
    }

    match /assessments/{assessmentId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || resource.data.isPublic == true);
      allow create: if isAuthenticated() && isValidAssessment(request.resource.data);
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid && isValidAssessmentUpdate(request.resource.data);
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /questions/{questionId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || resource.data.isPublic == true);
      allow create: if isAuthenticated() && isValidQuestion(request.resource.data);
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid && isValidQuestionUpdate(request.resource.data);
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /folders/{folderId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && isValidFolder(request.resource.data);
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid && isValidFolder(request.resource.data);
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /resources/{resourceId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || resource.data.isShared == true);
      allow create: if isAuthenticated() && isValidResource(request.resource.data);
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /syllabusCache/{resourceId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /pastPaperCache/{resourceId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }
  }
}
